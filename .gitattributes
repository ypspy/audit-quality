# =============================================================================
# audit-quality .gitattributes
# 모든 텍스트 파일을 LF로 정규화 (Windows CRLF 혼용 방지)
# =============================================================================

# 기본: 모든 텍스트 파일 LF 정규화
* text=auto eol=lf

# 명시적 텍스트 파일
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.env       text eol=lf
*.sh        text eol=lf
*.py        text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.txt       text eol=lf
*.xml       text eol=lf
Dockerfile  text eol=lf

# 바이너리 파일 (줄끝 변환 제외)
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.pdf       binary
