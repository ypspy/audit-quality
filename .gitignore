# =============================================================================
# Git worktrees
.worktrees/

# audit-quality 루트 .gitignore
#
# 이 루트 레포는 인프라·통합 레이어를 추적합니다.
# 아래 서비스들은 각자 독립적인 git 레포를 가지므로 루트에서 제외합니다:
#   - dart-for-auditor/
#   - local-inquiry-site/
#   - qualityEval/
#   - qualityPortal/
#   - quality-updates/
#   - quality-updates-crawler/
#   - timesheet/
# =============================================================================

# -----------------------------------------------------------------------------
# 독립 git 레포 서브프로젝트 (별도 레포로 관리)
# -----------------------------------------------------------------------------
dart-for-auditor/
local-inquiry-site/
qualityEval/
qualityPortal/
quality-updates/
quality-updates-crawler/
timesheet/

# -----------------------------------------------------------------------------
# 환경 변수 (절대 커밋 금지)
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.production
!.env.example

# -----------------------------------------------------------------------------
# Node.js
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-error.log*
.pnp
.pnp.js

# Next.js
.next/
out/
build/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# 가상환경
.venv/
venv/
env/
ENV/

# 패키징
*.egg
*.egg-info/
dist/
build/
eggs/
*.whl

# 테스트/커버리지
.pytest_cache/
.coverage
htmlcov/
.tox/

# MkDocs 빌드 결과
site/
.cache/

# -----------------------------------------------------------------------------
# 데이터 파일 (원문·다운로드·DB)
# -----------------------------------------------------------------------------
# Python 배치 스크립트 다운로드
downloads/*.pdf
downloads/*.hwp
downloads/*.zip

# SQLite DB
*.db
*.sqlite
*.sqlite3

# acme.json (Let's Encrypt 인증서 저장)
acme.json
traefik/acme.json

# -----------------------------------------------------------------------------
# TLS 인증서·키
# -----------------------------------------------------------------------------
*.pem
*.key
*.crt
*.csr
traefik/certs/*.pem
traefik/certs/*.key
traefik/certs/*.crt

# -----------------------------------------------------------------------------
# 로그
# -----------------------------------------------------------------------------
*.log
logs/
*.log.*

# -----------------------------------------------------------------------------
# IDE / 에디터
# -----------------------------------------------------------------------------
.vscode/
.idea/
.cursor/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# OS 생성 파일
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# Windows 장치 이름 파일 (잘못 생성된 경우)
nul
nul.*

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
# 로컬 오버라이드 (존재할 경우)
docker-compose.override.yml
docker-compose.local.yml

# -----------------------------------------------------------------------------
# 테스트 아티팩트
# -----------------------------------------------------------------------------
coverage/
.nyc_output/

# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Claude Code 내부 파일
# -----------------------------------------------------------------------------
.claude/

# -----------------------------------------------------------------------------
# 기타 아티팩트
# -----------------------------------------------------------------------------
# quality-updates-crawler 스크립트 출력물
quality-updates-crawler/scripts/hwp_extracted.txt
quality-updates-crawler/scripts/hwp_path.txt
quality-updates-crawler/scripts/pdf_extracted.txt
quality-updates-crawler/scripts/pdf_path.txt

# pyData 폴더 (서비스별 데이터 캐시)
*/pyData/
