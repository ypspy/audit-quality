# ============================================
# Docker Compose 전체 스택 환경 변수 예시
# ============================================
# 이 파일을 .env로 복사한 뒤 값을 채운 후: docker compose up -d

# --------------------------------------------
# Keycloak (Phase 1-3)
# --------------------------------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_DB_PASSWORD=keycloak
# 브라우저 접속 프로토콜과 맞출 것. http로 접속하면 http, https면 https
# KEYCLOAK_ISSUER=http://localhost/auth/realms/yss

# --------------------------------------------
# Traefik (Phase 1-2)
# --------------------------------------------
# HTTPS: 로컬은 자체 서명(기본), 프로덕션은 Let's Encrypt 사용 시
# traefik/traefik.yml 의 certificatesResolvers.letsencrypt.acme.email 과
# 동일하게 설정하거나, Traefik 실행 시 --certificatesresolvers.letsencrypt.acme.email=... 로 전달
# ACME_EMAIL=admin@your-domain.com

# --------------------------------------------
# MongoDB (모든 Node 서비스 공통)
# --------------------------------------------
# Compose 내부에서는 mongo:27017 사용. 로컬에서 개별 실행 시에만 필요.
# MONGODB_URI=mongodb://localhost:27017

# --------------------------------------------
# qualityPortal
# --------------------------------------------
# 포털 전용 DB는 Compose에서 MONGODB_URI로 자동 설정됨.

# --------------------------------------------
# qualityEval
# --------------------------------------------
# 세션 시크릿 (필수: 프로덕션에서 변경)
QUALITYEVAL_SECRET=change-me-in-production

# --------------------------------------------
# timesheet
# --------------------------------------------
SESSION_SECRET=change-me-in-production
# 관리자 초기 비밀번호 (Compose 기동 시 로그인용)
TIMESHEET_PASSWORD=admin

# --------------------------------------------
# dart-for-auditor
# --------------------------------------------
# OpenDART API 키 (선택, 수집 기능 사용 시 필요)
# https://opendart.fss.or.kr/uss/umt/EidGetAPIKey.do
# DART_API_KEY=

# --------------------------------------------
# local-inquiry-site
# --------------------------------------------
# Flask 세션 키
LOCAL_INQUIRY_SECRET_KEY=change-me-in-production
# Fernet 암호화 키 (EIN 등 민감정보, 생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
LOCAL_INQUIRY_ENCRYPTION_KEY=

# --------------------------------------------
# Phase 1-4: OpenTelemetry + Grafana
# --------------------------------------------
# 앱에서 메트릭/트레이스/로그를 보낼 Otel Collector 주소 (Compose 내부: http://otel-collector:4318)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# OTEL_SERVICE_NAME 는 서비스별로 docker-compose에서 설정됨

# Grafana 로그인 (기본: admin / admin)
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=admin

# --------------------------------------------
# Phase 2-1: Next.js 통합 UI (apps/web)
# --------------------------------------------
# dart-for-auditor API 프록시 (Docker: http://dart-for-auditor:4000, 로컬: http://localhost:4000)
# DART_INTERNAL_URL=http://localhost:4000
# local-inquiry-site API 프록시 (Docker: http://local-inquiry-site:8000, 로컬: http://localhost:8000)
# CLIENT_INTERNAL_URL=http://localhost:8000
# next-auth 암호화용 (필수: openssl rand -base64 32 로 생성 권장)
WEB_AUTH_SECRET=change-me-in-production
# Keycloak 공개 클라이언트 next-app 은 비밀 없음. confidential 로 둘 경우에만 설정
# WEB_AUTH_KEYCLOAK_SECRET=
# 브라우저 접속과 동일하게. http://localhost 로 접속하면 http, https면 https
WEB_AUTH_URL=http://localhost

# --------------------------------------------
# document-ingestor
# --------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here
QUALITY_UPDATES_HOST_PATH=../quality-updates

# document-ingestor BFF
DOCUMENT_INGESTOR_URL=http://document-ingestor:8010
